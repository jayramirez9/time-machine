{
  "cesiumGeoreference": {
    "objectPath": "/Game/TimeMachine-scene2a.TimeMachine-scene2a:PersistentLevel.CesiumGeoreference",
    "host": "http://localhost:30010",
    "defaultHeight": 0
  },
  "endpoints": {
    "unreal": {
      "transport": "unreal",
      "host": "http://localhost:30010",
      "actors": {
        "Cloud_GlobalCoverage": {
          "type": "material_scalar",
          "objectPath": "/Engine/EngineSky/VolumetricClouds/m_SimpleVolumetricCloud_Inst.m_SimpleVolumetricCloud_Inst",
          "parameterName": "Cloud_GlobalCoverage",
          "expressionGUID": { "A": 1427867580, "B": 1329756787, "C": -1312457547, "D": 1586639353 }
        },
        "StormClouds": {
          "type": "material_scalar",
          "objectPath": "/Engine/EngineSky/VolumetricClouds/m_SimpleVolumetricCloud_Inst.m_SimpleVolumetricCloud_Inst",
          "parameterName": "StormClouds",
          "expressionGUID": { "A": 0, "B": 0, "C": 0, "D": 0 }
        },
        "DirectionalLight.Elevation": {
          "type": "rotation",
          "objectPath": "/Temp/Untitled_1.Untitled_1:PersistentLevel.DirectionalLight_UAID_A85E45CFE40401D200_1470382761",
          "component": "Pitch"
        },
        "DirectionalLight.Azimuth": {
          "type": "rotation",
          "objectPath": "/Temp/Untitled_1.Untitled_1:PersistentLevel.DirectionalLight_UAID_A85E45CFE40401D200_1470382761",
          "component": "Yaw"
        },
        "SkyLight.Intensity": {
          "type": "property",
          "objectPath": "/Temp/Untitled_1.Untitled_1:PersistentLevel.SkyLight_UAID_A85E45CFE40401D200_1470380759",
          "componentPath": "SkyLightComponent0",
          "propertyName": "Intensity"
        },
        "ExponentialHeightFog.FogDensity": {
          "type": "property",
          "objectPath": "/Temp/Untitled_1.Untitled_1:PersistentLevel.ExponentialHeightFog_UAID_A85E45CFE40401D200_1470382763",
          "componentPath": "HeightFogComponent0",
          "propertyName": "FogDensity"
        }
      }
    },
    "dsp": {
      "transport": "osc",
      "host": "127.0.0.1",
      "port": 9000
    },
    "lighting": {
      "transport": "http",
      "url": "http://hue-bridge.local/api"
    }
  },
  "routes": [
    {
      "source": "controls.lighting.colorTempK",
      "endpoint": "lighting",
      "param": "colortemp",
      "transform": { "type": "scale", "inputRange": [3200, 6500], "outputRange": [153, 500] },
      "rateLimit": { "maxDelta": 20, "ema": 0.3 }
    },
    {
      "source": "controls.lighting.exteriorLuminance",
      "endpoint": "lighting",
      "param": "brightness",
      "transform": { "type": "scale", "inputRange": [0, 1], "outputRange": [0, 254] },
      "rateLimit": { "maxDelta": 10, "ema": 0.25 }
    },
    {
      "source": "controls.lighting.contrast",
      "endpoint": "lighting",
      "param": "contrast",
      "transform": { "type": "passthrough" }
    },
    {
      "source": "controls.audio.windLevel",
      "endpoint": "dsp",
      "param": "/buses/wind_bed/gain",
      "transform": { "type": "scale", "inputRange": [0, 1], "outputRange": [-60, 0] },
      "rateLimit": { "maxDelta": 6, "ema": 0.2 }
    },
    {
      "source": "controls.audio.rainLevel",
      "endpoint": "dsp",
      "param": "/buses/rain_bed/gain",
      "transform": { "type": "scale", "inputRange": [0, 1], "outputRange": [-60, 0] },
      "rateLimit": { "maxDelta": 6, "ema": 0.2 }
    },
    {
      "source": "controls.audio.baseNoiseFloorDb",
      "endpoint": "dsp",
      "param": "/buses/ambience/gain",
      "transform": { "type": "scale", "inputRange": [20, 60], "outputRange": [-40, 0] }
    },
    {
      "source": "controls.visual.sunAltitude",
      "endpoint": "unreal",
      "param": "DirectionalLight.Elevation",
      "transform": { "type": "passthrough" }
    },
    {
      "source": "controls.visual.sunAzimuth",
      "endpoint": "unreal",
      "param": "DirectionalLight.Azimuth",
      "transform": { "type": "passthrough" }
    },
    {
      "source": "controls.lighting.exteriorLuminance",
      "endpoint": "unreal",
      "param": "SkyLight.Intensity",
      "transform": { "type": "scale", "inputRange": [0, 1], "outputRange": [0.5, 4.0] },
      "rateLimit": { "maxDelta": 0.3, "ema": 0.3 }
    },
    {
      "source": "controls.atmosphere.cloudDensity",
      "endpoint": "unreal",
      "param": "Cloud_GlobalCoverage",
      "transform": { "type": "scale", "inputRange": [0, 1], "outputRange": [-0.5, 1.0] },
      "rateLimit": { "maxDelta": 0.1, "ema": 0.3 }
    },
    {
      "source": "controls.audio.thunderProb",
      "endpoint": "unreal",
      "param": "StormClouds",
      "transform": { "type": "curve", "gamma": 0.5, "outputRange": [0, 1.0] },
      "rateLimit": { "maxDelta": 0.05, "ema": 0.4 }
    },
    {
      "source": "controls.atmosphere.haze",
      "endpoint": "unreal",
      "param": "ExponentialHeightFog.FogDensity",
      "transform": { "type": "curve", "gamma": 2.0, "outputRange": [0, 0.05] },
      "rateLimit": { "maxDelta": 0.005, "ema": 0.25 }
    }
  ]
}
